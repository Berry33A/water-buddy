{
  "id": "water-buddy",
  "name": "Water Buddy - Hydration Tracker",
  "short_name": "WaterBuddy",
  "description": "Track your daily water intake with cute pets, mini-games, achievements, and gamification. Stay hydrated and have fun!",
  "lang": "en-US",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "orientation": "portrait-primary",
  "background_color": "#0ea5e9",
  "theme_color": "#0ea5e9",
  "categories": ["health", "lifestyle", "utilities", "medical"],
  "iarc_rating_id": "e84b0729-7b0e-4d4d-8b4a-9b0e4d4d8b4a",
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-48.png",
      "sizes": "48x48",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-36.png",
      "sizes": "36x36",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Add Water",
      "short_name": "Add",
      "description": "Quick add water intake",
      "url": "/?action=add"
    },
    {
      "name": "View Stats",
      "short_name": "Stats",
      "description": "View your hydration statistics",
      "url": "/?tab=stats"
    },
    {
      "name": "Play Game",
      "short_name": "Game",
      "description": "Play bubble pop game",
      "url": "/?action=game"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "file_handlers": [
    {
      "action": "/",
      "accept": { "application/json": [".waterbuddy"] }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    { "protocol": "web+waterbuddy", "url": "/?add=%s" }
  ],
  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred"
}